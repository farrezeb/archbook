#1769815987
# Criar arquivo de serviço
#1769815987
sudo tee /etc/systemd/system/disable-wake.service > /dev/null << 'EOF'
#1770834003
[Unit]
#1770834003
Description=Disable ACPI wake sources for MacBook (LID0)
#1770834003
After=multi-user.target
#1770834003
Before=sleep.target suspend.target
#1770834003
[Service]
#1770834003
Type=oneshot
#1770834003
ExecStart=/usr/local/bin/disable-wake.sh
#1770834003
RemainAfterExit=yes
#1770834003
[Install]
#1770834003
WantedBy=multi-user.target
#1770834003
EOF
#1769815996
# Recarregar systemd
