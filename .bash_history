#1770834003
#!/bin/bash
#1770834003
########################################################################################
#1770834003
# DISABLE WAKE SOURCES - MacBook A1278
#1770834003
# Desabilita LID0 (tampa) que acorda o sistema durante suspensão
#1770834003
########################################################################################
#1770834003
echo "=== Desabilitando Wake da Tampa (LID0) ==="
#1770834003
# Verificar se LID0 está habilitado
#1770834003
if grep -q "^LID0.*enabled" /proc/acpi/wakeup 2>/dev/null; then
#1770834003
    echo "LID0 está habilitado, desabilitando..."
#1770834003
    echo LID0 > /proc/acpi/wakeup
#1770834003
    echo "✓ LID0 desabilitado"
#1770834003
else
#1770834003
    echo "✓ LID0 já está desabilitado"
#1770834003
fi
#1770834003
echo ""
#1770834003
echo "Estado atual do LID0:"
#1770834003
grep LID0 /proc/acpi/wakeup
#1770834003
EOF
#1769815960
# Dar permissão
#1769815960
chmod +x disable-wake.sh
#1769815974
# Copiar para /usr/local/bin
#1769815974
sudo cp disable-wake.sh /usr/local/bin/
#1769815974
sudo chmod +x /usr/local/bin/disable-wake.sh
#1769815974
# Testar se funciona
#1769815974
sudo /usr/local/bin/disable-wake.sh
#1769815974
