#!/bin/bash
#1769629121
# Script para otimizar bgscan do wpa_supplicant
#1769629121
echo "=== Otimizando WiFi (bgscan) ==="
#1769629121
WPA_CONF="/etc/wpa_supplicant/wpa_supplicant.conf"
#1769629121
# Verificar se o arquivo existe
#1769629121
if [ ! -f "$WPA_CONF" ]; then     echo "Criando configuração do wpa_supplicant...";     sudo mkdir -p /etc/wpa_supplicant;     
#1770834003
    sudo tee "$WPA_CONF" > /dev/null << 'EOF'
#1770834003
# Configuração otimizada para MacBook
#1770834003
ctrl_interface=/run/wpa_supplicant
#1770834003
update_config=1
#1770834003
country=BR
#1770834003
# Desabilitar bgscan se causar problemas
#1770834003
# ou configurar de forma mais robusta
#1770834003
network={
#1770834003
    ssid="SUA_REDE"
#1770834003
    psk="SUA_SENHA"
#1770834003
    bgscan="simple:30:-70:300"
#1770834003
    priority=1
#1770834003
}
#1770834003
EOF
#1770834003
          echo "⚠ Arquivo criado com configuração exemplo";     echo "  Edite com: sudo micro $WPA_CONF"; else     echo "✓ Arquivo já existe: $WPA_CONF"; fi
#1769629121
echo "=== Alternativa: Usar apenas NetworkManager ==="
#1769629121
echo "Como você já usa NetworkManager, pode desabilitar wpa_supplicant:"
#1769629121
echo "  sudo systemctl disable wpa_supplicant"
#1769629121
echo "  sudo systemctl stop wpa_supplicant"
#1769629121
echo "NetworkManager gerencia WiFi internamente e não precisa do wpa_supplicant separado."
#1769629121
echo ""
#1769629121
echo "Para reverter:"
#1769629121
echo "  sudo systemctl enable wpa_supplicant"
#1769629121
echo "  sudo systemctl start wpa_supplicant"
