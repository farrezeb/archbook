#!/bin/bash
#1769629974
# Script para analisar core dumps do Hyprland
#1769629974
echo "=== Análise de Core Dumps do Hyprland ==="
#1769629974
# Verificar se coredumpctl está disponível
#1769629974
if ! command -v coredumpctl &> /dev/null; then     echo "❌ coredumpctl não encontrado";     echo "   Instale com: sudo pacman -S systemd";     exit 1; fi
#1769629974
echo "📊 Últimos crashes do Hyprland:"
#1769629974
coredumpctl list Hyprland | tail -10
#1769629974
echo "📋 Informações do último crash:"
#1769629974
coredumpctl info Hyprland | head -30
#1769629974
echo "🔍 Para análise detalhada:"
#1769629974
echo "   coredumpctl debug Hyprland"
#1769629974
echo "🗑️  Para limpar core dumps antigos:"
#1769629974
echo "   sudo coredumpctl --vacuum-time=1d"
#1769629974
echo "📈 Espaço usado por core dumps:"
#1769629974
du -sh /var/lib/systemd/coredump 2>/dev/null || echo "   Nenhum core dump armazenado"
#1769629974
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
#1769629974
echo ""
#1769629974
echo "🐛 Para reportar o bug:"
#1769629974
echo "   1. Acesse: https://github.com/hyprwm/Hyprland/issues"
#1769629974
echo "   2. Pesquise por 'aquamarine crash' ou 'DRM disconnect'"
#1769629974
echo "   3. Se não encontrar, crie um novo issue com:"
#1769629974
echo "      - Versão do Hyprland (hyprctl version)"
#1769629974
echo "      - Output deste script"
#1769629974
echo "      - Modelo do hardware (MacBook A1278)"
