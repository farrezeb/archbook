sudo cp disable-wake.sh /usr/local/bin/
#1769815974
sudo chmod +x /usr/local/bin/disable-wake.sh
#1769815974
# Testar se funciona
#1769815974
sudo /usr/local/bin/disable-wake.sh
#1769815974
