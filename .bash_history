#1769815987
# Criar arquivo de serviço
#1769815987
sudo tee /etc/systemd/system/disable-wake.service > /dev/null << 'EOF'
#1770834003
[Unit]
#1770834003
Description=Disable ACPI wake sources for MacBook (LID0)
#1770834003
After=multi-user.target
#1770834003
Before=sleep.target suspend.target
#1770834003
[Service]
#1770834003
Type=oneshot
#1770834003
ExecStart=/usr/local/bin/disable-wake.sh
#1770834003
RemainAfterExit=yes
#1770834003
[Install]
#1770834003
WantedBy=multi-user.target
#1770834003
EOF
#1769815996
# Recarregar systemd
#1769815996
sudo systemctl daemon-reload
#1769815997
# Habilitar (vai rodar no boot)
#1769815997
sudo systemctl enable disable-wake.service
#1769815997
# Iniciar agora
#1769815997
sudo systemctl start disable-wake.service
#1769815997
# Verificar status
#1769815997
sudo systemctl status disable-wake.service
#1769815997
