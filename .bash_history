#1769629974
echo "=== Análise de Core Dumps do Hyprland ==="
#1769629974
# Verificar se coredumpctl está disponível
#1769629974
if ! command -v coredumpctl &> /dev/null; then     echo "❌ coredumpctl não encontrado";     echo "   Instale com: sudo pacman -S systemd";     exit 1; fi
