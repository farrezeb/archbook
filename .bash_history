#!/bin/bash
#1769629097
# Script para configurar gnome-keyring com greetd
#1769629097
echo "=== Configurando gnome-keyring para greetd ==="
#1769629097
# Verificar se gnome-keyring está instalado
#1769629097
if ! pacman -Q gnome-keyring &> /dev/null; then     echo "Instalando gnome-keyring...";     sudo pacman -S --noconfirm gnome-keyring; fi
#1769629097
# Criar arquivo PAM para greetd
#1769629097
echo "Configurando PAM..."
#1769629097
sudo tee /etc/pam.d/greetd > /dev/null << 'EOF'
#1770834003
#%PAM-1.0
#1770834003
auth       required     pam_unix.so
#1770834003
auth       optional     pam_gnome_keyring.so
#1770834003
account    required     pam_unix.so
#1770834003
password   required     pam_unix.so
#1770834003
session    required     pam_limits.so
#1770834003
session    required     pam_unix.so
#1770834003
session    optional     pam_gnome_keyring.so auto_start
#1770834003
-session   optional     pam_systemd.so
#1770834003
EOF
#1769629097
# Adicionar inicialização do gnome-keyring no Hyprland
#1769629097
HYPR_CONF="$HOME/.config/hypr/hyprland.conf"
#1769629097
if ! grep -q "gnome-keyring-daemon" "$HYPR_CONF"; then     echo "";     echo "Adicionando gnome-keyring-daemon ao Hyprland...";     
#1770834003
