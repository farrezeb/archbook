#1770834003
[Service]
#1770834003
Type=oneshot
#1770834003
ExecStart=/usr/local/bin/disable-wake.sh
#1770834003
RemainAfterExit=yes
#1770834003
[Install]
#1770834003
WantedBy=multi-user.target
#1770834003
EOF
