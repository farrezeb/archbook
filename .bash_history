#!/bin/bash
#1769629020
# Script para silenciar aviso DMAR-IR no MacBook
#1769629020
echo "=== Silenciando aviso DMAR-IR do kernel ==="
#1769629020
echo "Este aviso é um bug de firmware da Apple e não afeta o funcionamento."
#1769629020
# Backup do grub
#1769629020
sudo cp /etc/default/grub /etc/default/grub.backup
#1769629020
# Adicionar parâmetro
#1769629020
if grep -q "intel_iommu=off" /etc/default/grub; then     echo "✓ Parâmetro já existe no GRUB"; else     echo "Adicionando 'intel_iommu=off' ao GRUB...";     sudo sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT="/GRUB_CMDLINE_LINUX_DEFAULT="intel_iommu=off /' /etc/default/grub;          echo "Atualizando configuração do GRUB...";     sudo grub-mkconfig -o /boot/grub/grub.cfg;          echo "";     echo "✓ Concluído! Reinicie para aplicar:";     echo "  sudo reboot"; fi
#1769629020
echo ""
#1769629020
echo "Backup salvo em: /etc/default/grub.backup"
#1769629053
cd /etc/default/
#1769629060
ll
#1769629073
...
