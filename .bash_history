#!/bin/bash
#1769629097
# Script para configurar gnome-keyring com greetd
#1769629097
echo "=== Configurando gnome-keyring para greetd ==="
#1769629097
# Verificar se gnome-keyring está instalado
#1769629097
if ! pacman -Q gnome-keyring &> /dev/null; then     echo "Instalando gnome-keyring...";     sudo pacman -S --noconfirm gnome-keyring; fi
#1769629097
# Criar arquivo PAM para greetd
#1769629097
echo "Configurando PAM..."
#1769629097
sudo tee /etc/pam.d/greetd > /dev/null << 'EOF'
#1770834003
#%PAM-1.0
#1770834003
auth       required     pam_unix.so
#1770834003
auth       optional     pam_gnome_keyring.so
#1770834003
account    required     pam_unix.so
#1770834003
password   required     pam_unix.so
#1770834003
session    required     pam_limits.so
#1770834003
session    required     pam_unix.so
#1770834003
session    optional     pam_gnome_keyring.so auto_start
#1770834003
-session   optional     pam_systemd.so
#1770834003
EOF
#1769629097
# Adicionar inicialização do gnome-keyring no Hyprland
#1769629097
HYPR_CONF="$HOME/.config/hypr/hyprland.conf"
#1769629097
if ! grep -q "gnome-keyring-daemon" "$HYPR_CONF"; then     echo "";     echo "Adicionando gnome-keyring-daemon ao Hyprland...";     
#1770834003
    cp "$HYPR_CONF" "$HYPR_CONF.backup";     
#1770834003
    sed -i '/polkit-gnome-authentication-agent/a exec-once = gnome-keyring-daemon --start --components=secrets,ssh' "$HYPR_CONF";          echo "✓ Linha adicionada no hyprland.conf";     echo "  Backup salvo em: $HYPR_CONF.backup"; else     echo "✓ gnome-keyring-daemon já configurado no Hyprland"; fi
#1769629097
echo "=== Configuração concluída ==="
#1769629097
echo "Para aplicar as mudanças:"
#1769629097
echo "  1. Faça logout (Super+M)"
#1769629097
echo "  2. Faça login novamente"
#1769629097
echo ""
#1769629097
echo "Para testar se está funcionando:"
#1769629097
echo "  gnome-keyring-daemon --version"
#1769629097
echo "Para aplicar as mudanças:"
#1769629097
echo "  1. Faça logout (Super+M)"
#1769629097
echo "  2. Faça login novamente"
#1769629097
echo "Para testar se está funcionando:"
#1769629097
echo "  gnome-keyring-daemon --version"
