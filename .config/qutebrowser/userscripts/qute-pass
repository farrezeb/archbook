#!/bin/bash
# Qutebrowser userscript para Pass - corrigido

export PATH="/usr/local/bin:/usr/bin:/bin:$HOME/.local/bin:$PATH"

# Pega domínio da URL
domain=$(echo "$QUTE_URL" | awk -F/ '{print $3}' | sed 's/www\.//;s/login\.//;s/signin\.//;s/\.com//;s/\.org//;s/\.net//;s/\.br//')

# CORREÇÃO: Lista entradas corretamente
store_path="$HOME/.password-store"
entries=$(find "$store_path" -name "*.gpg" -type f 2>/dev/null | \
    sed "s|$store_path/||g; s|\.gpg$||g" | \
    sort)

# Debug
echo "Domain: $domain" >> /tmp/qute-pass.log
echo "Entries: $entries" >> /tmp/qute-pass.log

# Tenta match com domínio
if [ -n "$domain" ]; then
    match=$(echo "$entries" | grep -i "$domain" | head -1)
fi

# Seleciona
if [ -n "$match" ]; then
    selected="$match"
    echo "Auto-match: $selected" >> /tmp/qute-pass.log
else
    selected=$(echo "$entries" | fuzzel --dmenu --prompt="Senha: " --lines=15)
    echo "Manual: $selected" >> /tmp/qute-pass.log
fi

# Copia senha
if [ -n "$selected" ]; then
    password=$(pass show "$selected" 2>/dev/null | head -1)

    if [ -n "$password" ]; then
        echo "$password" | wl-copy --trim-newline
        notify-send "Pass" "Senha de $selected copiada (45s)"
    else
        notify-send "Pass" "Erro: entrada não encontrada"
    fi
fi
