#!/bin/bash
# Qutebrowser userscript para Pass - corrigido para fuzzel/qutebrowser

export PATH="/usr/local/bin:/usr/bin:/bin:$HOME/.local/bin:$PATH"

# Verifica se está rodando dentro do qutebrowser
if [ -z "$QUTE_FIFO" ]; then
    echo "Erro: QUTE_FIFO não definido. Execute via qutebrowser." >&2
    exit 1
fi

# Pega domínio da URL
domain=$(echo "$QUTE_URL" | awk -F/ '{print $3}' | sed 's/www\.//;s/login\.//;s/signin\.//')

# Lista entradas do pass
store_path="$HOME/.password-store"
entries=$(find "$store_path" -name "*.gpg" -type f 2>/dev/null | \
    sed "s|$store_path/||g; s|\.gpg$||g" | \
    sort)

# Debug
echo "message-info 'Domain: $domain'" >> "$QUTE_FIFO"

# Tenta match com domínio
match=""
if [ -n "$domain" ]; then
    match=$(echo "$entries" | grep -i "$domain" | head -1)
fi

# Seleciona com fuzzel
if [ -n "$match" ]; then
    selected="$match"
    echo "message-info 'Auto-match: $selected'" >> "$QUTE_FIFO"
else
    selected=$(echo "$entries" | fuzzel --dmenu --prompt="Senha: " --lines=15 2>/dev/null)
fi

# Se cancelou o fuzzel (esc), sai
if [ -z "$selected" ]; then
    echo "message-info 'Seleção cancelada'" >> "$QUTE_FIFO"
    exit 0
fi

# Extrai dados do pass
full_entry=$(pass show "$selected" 2>/dev/null)

if [ -z "$full_entry" ]; then
    echo "message-error 'Erro ao acessar $selected'" >> "$QUTE_FIFO"
    exit 1
fi

# Extrai senha (1ª linha)
password=$(echo "$full_entry" | head -n 1)

# Extrai usuário do campo 'login:'
username=$(echo "$full_entry" | grep "^login:" | head -n 1 | sed 's/^login: //')

echo "message-info 'User: $username'" >> "$QUTE_FIFO"

# Preenche campos via JavaScript (formato corrigido)
if [ -n "$password" ]; then
    if [ -n "$username" ]; then
        # Usuário + Senha
        js_code="(function() {
            var inputs = document.querySelectorAll('input');
            var userFilled = false;
            var passFilled = false;

            for (var i = 0; i < inputs.length; i++) {
                var input = inputs[i];
                var type = input.type.toLowerCase();
                var name = (input.name || '').toLowerCase();
                var id = (input.id || '').toLowerCase();
                var placeholder = (input.placeholder || '').toLowerCase();

                // Detecta campo de usuário/email
                if (!userFilled && (type === 'email' || name.includes('email') || id.includes('email') ||
                    name.includes('user') || id.includes('user') || name.includes('login') ||
                    id.includes('login') || placeholder.includes('email') || placeholder.includes('usuário'))) {
                    input.value = '$username';
                    input.dispatchEvent(new Event('input', {bubbles: true}));
                    input.dispatchEvent(new Event('change', {bubbles: true}));
                    userFilled = true;
                }

                // Detecta campo de senha
                if (!passFilled && type === 'password') {
                    input.value = '$password';
                    input.dispatchEvent(new Event('input', {bubbles: true}));
                    input.dispatchEvent(new Event('change', {bubbles: true}));
                    passFilled = true;
                }
            }

            return 'Usuário: ' + userFilled + ', Senha: ' + passFilled;
        })()"

        echo "jseval $js_code" >> "$QUTE_FIFO"
        echo "message-info 'Preenchendo $selected'" >> "$QUTE_FIFO"
    else
        # Só senha
        js_code="(function() {
            var p = document.querySelector('input[type=password]');
            if (p) {
                p.value = '$password';
                p.dispatchEvent(new Event('input', {bubbles: true}));
                return 'Senha preenchida';
            }
            return 'Campo de senha não encontrado';
        })()"

        echo "jseval $js_code" >> "$QUTE_FIFO"
        echo "message-info 'Senha preenchida (sem usuário)'" >> "$QUTE_FIFO"
    fi
else
    echo "message-error 'Senha vazia'" >> "$QUTE_FIFO"
fi
