#!/usr/bin/env bash

clean() {
  sed 's/\x1b\[[0-9;]*m//g'
}

SCROLL="$(kitty @ get-text --extent=screen | clean)"

CHOICE=$(printf "%s\n" "$SCROLL" \
| awk '/^\[[^]]+@[^]]+ [^]]+\]\$ / {cmd[++n]=$0}
END {
  for (i=n; i>=1; i--)
    print i " │ " cmd[i]
}' \
| fzf --prompt="Comando > ")

[ -z "$CHOICE" ] && exit 0

IDX=$(echo "$CHOICE" | awk '{print $1}')

printf "%s\n" "$SCROLL" \
| awk -v idx="$IDX" '
/^\[[^]]+@[^]]+ [^]]+\]\$ /{c++}
c==idx {next}
c==idx+1 {exit}
c>idx {print}
' \
| wl-copy
