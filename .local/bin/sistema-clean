#!/bin/bash
# ============================================================
# sistema-clean — limpeza geral do sistema (Arch Linux / yay)
# Uso: sistema-clean [--dry-run]
# ============================================================

set -euo pipefail

# ---------- flags ----------
DRY=false
for arg in "$@"; do
    case "$arg" in
        --dry-run|-n) DRY=true ;;
        --help|-h)
            echo "Uso: $(basename "$0") [--dry-run|-n]"
            echo "  --dry-run  Mostra o que seria removido sem deletar nada"
            exit 0 ;;
        *) echo "Opção desconhecida: $arg"; exit 1 ;;
    esac
done

# ---------- cores ----------
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

info()    { echo -e "${CYAN}==> ${RESET}${BOLD}$*${RESET}"; }
ok()      { echo -e "${GREEN}  ✓ ${RESET}$*"; }
warn()    { echo -e "${YELLOW}  ! ${RESET}$*"; }
dry()     { echo -e "${YELLOW}  ~ ${RESET}[dry-run] $*"; }
section() { echo -e "\n${BOLD}${CYAN}── $* ──${RESET}"; }

# Executa ou simula um comando destrutivo
run() {
    if $DRY; then
        dry "$*"
    else
        eval "$*"
    fi
}

$DRY && warn "Modo dry-run ativo — nenhum arquivo será removido\n"

# ---------- capturas de tela ----------
section "Limpando Capturas de Tela"
CAPTURAS="$HOME/media/Capturas de tela"
if [[ -d "$CAPTURAS" ]]; then
    FILES=$(find "$CAPTURAS" -maxdepth 1 -type f)
    COUNT=$(echo "$FILES" | grep -c . || true)
    if [[ "$COUNT" -gt 0 ]]; then
        if $DRY; then
            dry "Removeria $COUNT arquivo(s):"
            echo "$FILES" | sed 's/^/      /'
        else
            rm -f "$CAPTURAS"/*
            ok "Removidos $COUNT arquivo(s)"
        fi
    else
        ok "Nenhuma captura encontrada"
    fi
else
    warn "Diretório não existe: $CAPTURAS"
fi

# ---------- cache de pacotes ----------
section "Limpando Cache de Pacotes (pacman)"
if $DRY; then
    dry "paccache -rk2 (manteria 2 versões por pacote instalado)"
    dry "paccache -ruk0 (removeria todas versões de pacotes desinstalados)"
    sudo paccache -dk2
    sudo paccache -duk0
else
    sudo paccache -rk2
    sudo paccache -ruk0
fi

section "Limpando Cache de Pacotes (yay / AUR)"
YAY_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/yay"
if [[ -d "$YAY_CACHE" ]]; then
    AUR_FILES=$(find "$YAY_CACHE" -mindepth 2 -maxdepth 2 \
        -type f \( -name "*.tar.*" -o -name "*.zip" -o -name "*.gz" \) 2>/dev/null || true)
    AUR_COUNT=$(echo "$AUR_FILES" | grep -c . || true)
    if $DRY; then
        if [[ "$AUR_COUNT" -gt 0 ]]; then
            dry "Removeria $AUR_COUNT arquivo(s) do cache AUR:"
            echo "$AUR_FILES" | sed 's/^/      /'
        else
            dry "Nenhum arquivo de cache AUR encontrado"
        fi
    else
        echo "$AUR_FILES" | xargs -r rm -f
        ok "Cache AUR limpo"
    fi
else
    ok "Nenhum cache AUR encontrado"
fi

# ---------- órfãos ----------
section "Removendo Pacotes Órfãos"
ORPHANS=$(pacman -Qdtq 2>/dev/null || true)
if [[ -n "$ORPHANS" ]]; then
    if $DRY; then
        dry "Removeria os seguintes órfãos:"
        echo "$ORPHANS" | sed 's/^/      /'
    else
        echo "$ORPHANS" | xargs sudo pacman -Rns --noconfirm
        ok "Órfãos removidos"
    fi
else
    ok "Nenhum órfão encontrado"
fi

# ---------- snapshots do timeshift ----------
section "Limpando Snapshots do Timeshift (mantendo 3)"
SNAPSHOTS=$(sudo timeshift --list 2>/dev/null \
    | grep -oP '\d{4}-\d{2}-\d{2}_\d{2}-\d{2}-\d{2}' \
    | head -n -3 || true)

if [[ -n "$SNAPSHOTS" ]]; then
    if $DRY; then
        dry "Removeria os seguintes snapshots:"
        echo "$SNAPSHOTS" | sed 's/^/      /'
    else
        while IFS= read -r snap; do
            info "Removendo snapshot: $snap"
            sudo timeshift --delete --snapshot "$snap" --scripted
        done <<< "$SNAPSHOTS"
        ok "Snapshots antigos removidos"
    fi
else
    ok "Nada a remover (≤ 3 snapshots)"
fi

# ---------- logs ----------
section "Limpando Logs do Sistema (> 30 dias)"
if $DRY; then
    dry "journalctl --vacuum-time=30d"
    sudo journalctl --verify 2>/dev/null | tail -1 || true
    dry "find /var/log/timeshift/ -type f -mtime +7 -delete"
    sudo find /var/log/timeshift/ -type f -mtime +7 2>/dev/null \
        | sed 's/^/      /' || true
else
    sudo journalctl --vacuum-time=30d
    sudo find /var/log/timeshift/ -type f -mtime +7 -delete 2>/dev/null || true
    ok "Logs limpos"
fi

# ---------- downloads antigos ----------
section "Limpando Downloads Antigos (> 90 dias)"
DL_DIR="$HOME/dl"
if [[ -d "$DL_DIR" ]]; then
    if command -v fd &>/dev/null; then
        DL_FILES=$(fd . "$DL_DIR" --maxdepth 1 --type f --changed-before 90d 2>/dev/null || true)
    else
        DL_FILES=$(find "$DL_DIR" -maxdepth 1 -type f -mtime +90 2>/dev/null || true)
    fi
    DL_COUNT=$(echo "$DL_FILES" | grep -c . || true)
    if $DRY; then
        if [[ "$DL_COUNT" -gt 0 ]]; then
            dry "Removeria $DL_COUNT arquivo(s) de $DL_DIR:"
            echo "$DL_FILES" | sed 's/^/      /'
        else
            dry "Nenhum arquivo antigo em $DL_DIR"
        fi
    else
        echo "$DL_FILES" | xargs -r rm -f
        ok "Removidos ~$DL_COUNT arquivo(s) antigo(s)"
    fi
else
    warn "Diretório não existe: $DL_DIR"
fi

# ---------- caches de aplicativos ----------
section "Limpando Caches de Aplicativos"

_rm() {
    local target="$1" label="$2"
    local matched
    matched=$(compgen -G "$target" 2>/dev/null || true)
    if [[ -n "$matched" ]]; then
        if $DRY; then
            dry "Removeria: $label"
            echo "$matched" | sed 's/^/      /'
        else
            rm -rf $target
            ok "$label"
        fi
    fi
}

_rm "$HOME/.cache/qutebrowser/qtsql/*.sqlite-wal" "qutebrowser WAL"
_rm "$HOME/.cache/thumbnails/*"                    "Thumbnails"
_rm "$HOME/.config/micro/buffers/*"               "Micro buffers"

# ---------- docker ----------
section "Limpando Docker"
if command -v docker &>/dev/null && docker info &>/dev/null 2>&1; then
    if $DRY; then
        dry "Containers parados que seriam removidos:"
        docker ps -a --filter status=exited --filter status=created \
            --format "      {{.Names}} ({{.Image}})" 2>/dev/null || true
        dry "Imagens sem uso (dangling):"
        docker images --filter dangling=true \
            --format "      {{.Repository}}:{{.Tag}} {{.ID}}" 2>/dev/null || true
        dry "Volumes órfãos:"
        docker volume ls --filter dangling=true \
            --format "      {{.Name}}" 2>/dev/null || true
        dry "Cache de build seria limpo"
    else
        STOPPED=$(docker ps -aq --filter status=exited --filter status=created 2>/dev/null || true)
        if [[ -n "$STOPPED" ]]; then
            echo "$STOPPED" | xargs docker rm
            ok "Containers parados removidos"
        else
            ok "Nenhum container parado"
        fi
        docker image prune -f &>/dev/null
        ok "Imagens dangling removidas"
        docker volume prune -f &>/dev/null
        ok "Volumes órfãos removidos"
        docker builder prune -f &>/dev/null
        ok "Cache de build limpo"
    fi
else
    warn "Docker não está rodando ou não está instalado — pulando"
fi

# ---------- cache geral ----------
section "Relatório de Cache Restante"
du -sh "$HOME/.cache" 2>/dev/null | awk '{print "  Cache total em ~/.cache: " $1}'

if $DRY; then
    echo -e "\n${YELLOW}${BOLD}~ Dry-run concluído — nenhum arquivo foi removido.${RESET}\n"
else
    echo -e "\n${GREEN}${BOLD}✔ Limpeza concluída!${RESET}\n"
fi
